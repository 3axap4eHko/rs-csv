{
  "name": "@rs-csv/core",
  "version": "0.0.0",
  "description": "Fast CSV parser powered by Rust with SIMD acceleration",
  "keywords": [
    "csv",
    "parser",
    "rust",
    "simd",
    "napi",
    "fast",
    "typed"
  ],
  "license": "MIT",
  "author": "Ivan Zakharchanka <3axap4eHko@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/3axap4eHko/rs-csv.git",
    "directory": "packages/rs-csv"
  },
  "homepage": "https://github.com/3axap4eHko/rs-csv/tree/master/packages/rs-csv",
  "bugs": "https://github.com/3axap4eHko/rs-csv/issues",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "napi": {
    "binaryName": "rs-csv",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "tsc",
    "version": "napi version",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
