{
  "private": true,
  "scripts": {
    "build:napi": "cd crates/napi && RUSTFLAGS=\"-C target-cpu=native\" ./node_modules/.bin/napi build --release",
    "build:wasm": "RUSTFLAGS=\"-C target-feature=+simd128\" wasm-pack build crates/wasm --target nodejs --release && echo 'exports.memory = wasm.memory;' >> crates/wasm/pkg/rs_csv_wasm.js",
    "build": "pnpm run build:napi && pnpm run build:wasm",
    "lint": "oxlint packages/rs-csv/src/ && cargo clippy --workspace",
    "fmt": "cargo fmt --all",
    "test": "bun test packages/rs-csv/test/",
    "bench": "overtake packages/rs-csv/bench/bench.ts -w 1 --progress"
  },
  "devDependencies": {
    "@types/papaparse": "^5",
    "csv-parse": "^6.2.1",
    "csv-rex": "^0.7.0",
    "d3-dsv": "^3.0.1",
    "fast-csv": "^5.0.5",
    "overtake": "^2.0.3",
    "oxlint": "^1.57.0",
    "papaparse": "^5",
    "udsv": "^0.7.3"
  },
  "workspaces": [
    "packages/*"
  ]
}
